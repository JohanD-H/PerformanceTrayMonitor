<Application x:Class="PerformanceTrayMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PerformanceTrayMonitor"
             xmlns:conv="clr-namespace:PerformanceTrayMonitor.Converters"
             ShutdownMode="OnExplicitShutdown">

    <Application.Resources>

        <!-- Converters available to the whole app -->
        <conv:ActivityToBrushConverter x:Key="ActivityToBrush"/>

        <!-- Shared gradient for AboutWindow and ConfigWindow -->
        <LinearGradientBrush x:Key="AppWindowGradient"
                             StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0F6FF" Offset="0"/>
            <GradientStop Color="#D0DCEC" Offset="1"/>
        </LinearGradientBrush>

    </Application.Resources>
</Application>
