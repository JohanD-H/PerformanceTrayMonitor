<Window x:Class="PerformanceTrayMonitor.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PerformanceTrayMonitor.Views"
        xmlns:conv="clr-namespace:PerformanceTrayMonitor.Converters"
        Title="Metrics View"
        MinWidth="150"
        MinHeight="100"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Topmost="{Binding PopupPinned}"
        Opacity="0">

    <!-- Resources -->
    <Window.Resources>

        <conv:ValueToSizeConverter x:Key="ValueToSize"
                                   MinSize="6"
                                   MaxSize="14"/>

        <!-- Smooth easing -->
        <QuadraticEase x:Key="EaseOut" EasingMode="EaseOut"/>

        <!-- Subtle grid background for sparkline panels -->
        <DrawingBrush x:Key="SparklineGridBrush"
              TileMode="Tile"
              Viewport="0,0,16,12"
              ViewportUnits="Absolute"
              Stretch="None">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen>
                        <!-- ~6% opacity white lines -->
                        <Pen Thickness="1" Brush="#30000000"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <!-- Vertical line -->
                            <LineGeometry StartPoint="0,0" EndPoint="0,12"/>
                            <!-- Horizontal line -->
                            <LineGeometry StartPoint="0,0" EndPoint="16,0"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="P"
                Modifiers="Control"
                Command="{Binding TogglePopupPinnedCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}" />

        <KeyBinding Key="Escape"
                Command="{Binding ClosePopupCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}" />
    </Window.InputBindings>

    <!-- Main Layout -->
    <DockPanel x:Name="Root"
               Background="{StaticResource AppWindowGradient}"
               RenderTransformOrigin="0.5,0.5">

        <DockPanel.RenderTransform>
            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
        </DockPanel.RenderTransform>

        <!-- Title Bar -->
        <Grid x:Name="TitleBar"
              DockPanel.Dock="Top"
              Height="28"
              Background="#444"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Background" Value="#444"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PopupPinned}" Value="True">
                            <Setter Property="Background" Value="#555"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Metrics View"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Foreground="White"/>

            <!-- Pin Button -->
            <ToggleButton Grid.Column="1"
                          Width="28"
                          Height="28"
                          Margin="0,0,2,0"
                          IsChecked="{Binding PopupPinned}"
                          ToolTip="Pin / Unpin (Ctrl+P)">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Content" Value="📌"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="📍"/>
                                <Setter Property="Background" Value="#666"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <!-- Close Button -->
            <Button Grid.Column="2"
                    Width="28"
                    Height="28"
                    Margin="0,0,4,0"
                    Content="✕"
                    Foreground="White"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    ToolTip="Close"
                    Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#666"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#888"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <ItemsControl x:Name="MetricsList"
                          ItemsSource="{Binding Counters}"
                          VirtualizingPanel.IsVirtualizing="False"
                          ScrollViewer.CanContentScroll="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border Margin="4"
                                Padding="6"
                                BorderBrush="#555"
                                BorderThickness="1"
                                CornerRadius="3">

                            <StackPanel>

                                <Border MouseLeftButtonUp="ShowGraph_Click"
                                        Cursor="Hand"
                                        Margin="4"
                                        Padding="6"
                                        ToolTip="Enlarge Graph">

                                    <!-- Display Name + Dot -->
                                    <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,4">
                                        <Ellipse Width="10"
                                                Height="10"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"
                                                Fill="{Binding CurrentValue, Converter={StaticResource ActivityToBrush}}"/>
                                        <TextBlock x:Name="DisplayNameBlock"
                                               Text="{Binding DisplayName}"
                                               Foreground="{Binding AccentBrush}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center">
                                               <!-- MouseLeftButtonDown="DisplayNameBlock_MouseLeftButtonDown" -->
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="Black"
                                                              BlurRadius="2"
                                                              ShadowDepth="0"
                                                              Opacity="0.5"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>

                                </Border>

                                <!-- Sparkline + Value -->
                                <Grid Height="24"
                                      Background="{StaticResource SparklineGridBrush}">

                                    <local:SparkLine Values="{Binding Path=History, Mode=OneWay}"
                                                     Min="{Binding Min}"
                                                     Max="{Binding Max}"
                                                     Stroke="{Binding AccentBrush}"
                                                     Opacity="0.85">
                                        <local:SparkLine.Effect>
                                            <DropShadowEffect Color="Black"
                                                              BlurRadius="4"
                                                              ShadowDepth="0"
                                                              Opacity="0.5"
                                            />
                                        </local:SparkLine.Effect>
                                    </local:SparkLine>

                                    <TextBlock Text="{Binding CurrentValue, StringFormat=0.0}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="#88000000"
                                               Margin="0,0,2,0"
                                               FontSize="11">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="Black"
                                                              BlurRadius="3"
                                                              ShadowDepth="0"
                                                              Opacity="0.5"/>
                                        </TextBlock.Effect>
                                    </TextBlock>

                                </Grid>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </ScrollViewer>

    </DockPanel>

</Window>