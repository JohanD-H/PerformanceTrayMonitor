<Window x:Class="PerformanceTrayMonitor.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PerformanceTrayMonitor.Views"
        xmlns:conv="clr-namespace:PerformanceTrayMonitor.Converters"
        Title="Metrics View"
        MinWidth="150"
        MinHeight="100"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Topmost="{Binding PopupPinned}">

    <Window.Resources>
        <conv:ValueToSizeConverter x:Key="ValueToSize"
                                   MinSize="6"
                                   MaxSize="14"/>
    </Window.Resources>

    <DockPanel Background="{StaticResource AppWindowGradient}">

        <!-- Title Bar -->
        <Grid x:Name="TitleBar"
              DockPanel.Dock="Top"
              Height="28"
              Background="#444"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Background" Value="#444"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PopupPinned}" Value="True">
                            <Setter Property="Background" Value="#555"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Metrics View"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Foreground="White"/>

            <!-- Pin Button -->
            <ToggleButton Grid.Column="1"
                  Width="28"
                  Height="28"
                  Margin="0,0,2,0"
                  IsChecked="{Binding PopupPinned}"
                  ToolTip="Pin / Unpin">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Content" Value="📌"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="📍"/>
                                <Setter Property="Background" Value="#666"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <!-- Close Button -->
            <Button Grid.Column="2"
                    Width="28"
                    Height="28"
                    Margin="0,0,4,0"
                    Content="✕"
                    Foreground="White"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    ToolTip="Close"
                    Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#666"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#888"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <ItemsControl ItemsSource="{Binding Counters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border Margin="4"
                                Padding="6"
                                BorderBrush="#555"
                                BorderThickness="1"
                                CornerRadius="3">

                            <StackPanel>

                                <!-- Display Name + Dot -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="10"
                                             Height="10"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0"
                                             Fill="{Binding CurrentValue, Converter={StaticResource ActivityToBrush}}"/>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Sparkline + Value -->
                                <Grid Height="24"
                                      Background="#77000000">

                                    <local:SparkLine Values="{Binding History}"
                                                     Min="{Binding Min}"
                                                     Max="{Binding Max}"
                                                     Opacity="0.85"/>

                                    <TextBlock Text="{Binding CurrentValue, StringFormat=0.0}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="#FFFFFFFF"
                                               Margin="0,0,2,0"
                                               FontSize="11">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="Black"
                                                              BlurRadius="3"
                                                              ShadowDepth="0"
                                                              Opacity="0.6"/>
                                        </TextBlock.Effect>
                                    </TextBlock>

                                </Grid>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </ScrollViewer>

    </DockPanel>

</Window>
