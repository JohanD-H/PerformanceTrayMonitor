<Window x:Class="PerformanceTrayMonitor.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PerformanceTrayMonitor.Views"
        xmlns:conv="clr-namespace:PerformanceTrayMonitor.Converters"
        Title="Performance"
        MinWidth="260" MinHeight="100"
        Width="260" Height="100"
        SizeToContent="WidthAndHeight"
        WindowStyle="ToolWindow"
        Topmost="True">

    <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Counters}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>

                    <Border Margin="4" Padding="4" BorderBrush="Gray" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <!-- Activity Dot -->
                            <Ellipse Width="12" Height="12" Margin="0,0,8,0"
                                     Visibility="{Binding Mode, Converter={StaticResource ModeToVisibility}, ConverterParameter=Activity}"
                                     Fill="{Binding CurrentValue, Converter={StaticResource ActivityToBrush}}"/>

                            <!-- Graph -->
                            <local:Sparkline Width="80" Height="20" Margin="0,0,8,0"
                                             Visibility="{Binding Mode, Converter={StaticResource ModeToVisibility}, ConverterParameter=Graph}"
                                             Values="{Binding History}"/>

                            <!-- Numeric -->
                            <TextBlock Margin="0,0,8,0"
                                       Visibility="{Binding Mode, Converter={StaticResource ModeToVisibility}, ConverterParameter=Value}"
                                       Text="{Binding CurrentValue, StringFormat=0.0}"/>

                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentValue, StringFormat=0.0}" FontSize="11"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>

</Window>
