<Window x:Class="PerformanceTrayMonitor.Views.MetricGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PerformanceTrayMonitor.Views"
        xmlns:conv="clr-namespace:PerformanceTrayMonitor.Converters"
        Title="Metric Graph"
        Width="430"
        Height="260"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <DrawingBrush x:Key="SparklineGridBrush"
                        TileMode="Tile"
                        Viewport="0,0,16,12"
                        ViewportUnits="Absolute"
                        Stretch="None">
            <!-- Was Viewport="0,0,16,12" -->
            <!-- Was Viewport="-40,0,16,12" -->
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen>
                        <Pen Thickness="1" Brush="#30000000"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="0,12"/>
                            <LineGeometry StartPoint="0,0" EndPoint="16,0"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <conv:SnapToGridHeightConverter x:Key="SnapToGridHeightConverter"/>
        
    </Window.Resources>

    <!-- Background="#FFCFC4D0" -->
    <Border CornerRadius="8"
            Background="{StaticResource AppWindowGradient}"
            BorderBrush="transparent"
            BorderThickness="0"
            Padding="12">
    
        <Border.Effect>
            <DropShadowEffect BlurRadius="12"
                            ShadowDepth="0"
                            Opacity="0.35"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <DockPanel Grid.Row="0"
                        Margin="0 0 0 8"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <!-- Close button -->
                <Button Content="✕"
                        Width="28"
                        Height="28"
                        DockPanel.Dock="Right"
                        Background="Transparent"
                        FontWeight="Bold"
                        Foreground="#FF3E1919"
                        BorderBrush="Transparent"
                        Click="CloseButton_Click"/>

                <!-- Title  -->
                <TextBlock Text="{Binding DisplayName}"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="{Binding AccentBrush}"
                            VerticalAlignment="Center"/>

            </DockPanel>

            <!-- Graph -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <!-- Labels only -->
                    <ColumnDefinition Width="*"/>
                    <!-- Plot area -->
                </Grid.ColumnDefinitions>

                <!-- Y-axis LABELS -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Max -->
                        <RowDefinition Height="*"/>
                        <!-- Spacer -->
                        <RowDefinition Height="Auto"/>
                        <!-- Min -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding Max}"
                               Foreground="#FF120D0D"
                               FontSize="10"/>

                    <TextBlock Grid.Row="2"
                               Text="{Binding Min}"
                               Foreground="#FF120D0D"
                               FontSize="10"/>
                </Grid>

                <!-- Plot area (grid + sparkline + axes) -->
                <Grid Grid.Column="1">
                    
                    <!-- Grid -->
                    <local:GridLines CellWidth="16"
                                     CellHeight="12"
                                     LineThickness="1"
                                     LineBrush="#30000000"/>

                    <!-- Y-axis line -->
                    <Line X1="0" Y1="0"
                          X2="0"
                          Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=local:SparkLine}}"
                          Stroke="#66000000"
                          StrokeThickness="2"
                          HorizontalAlignment="Left"/>

                    <!-- X-axis -->
                    <local:XAxis LineBrush="#55000000"
                                 LineThickness="2"
                                 VerticalAlignment="Bottom"/>

                    <!-- Sparkline (TOPMOST) -->
                    <local:SparkLine x:Name="Spark"
                                     Values="{Binding History}"
                                     Min="{Binding Min}"
                                     Max="{Binding Max}"
                                     Stroke="{Binding AccentBrush}"
                                     StrokeThickness="2"
                                     Opacity="0.85"/>
                </Grid>

            </Grid>

            <!-- Stats -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0 8 0 0">

                <StackPanel Margin="12 0">
                    <TextBlock Text="Current"
                                Foreground="#FF5C5252"
                                FontSize="12"/>
                    <TextBlock Text="{Binding CurrentValue, StringFormat=0.0}"
                                Foreground="#FF120D0D"
                                FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Margin="12 0">
                    <TextBlock Text="Min"
                                Foreground="#FF5C5252"
                                FontSize="12"/>
                    <TextBlock Text="{Binding Min}"
                                Foreground="#FF120D0D"
                                FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Margin="12 0">
                    <TextBlock Text="Max"
                                Foreground="#FF5C5252"
                                FontSize="12"/>
                    <TextBlock Text="{Binding Max}"
                                Foreground="#FF120D0D"
                                FontWeight="Bold"/>
                </StackPanel>

            </StackPanel>

        </Grid>
    </Border>
</Window>
