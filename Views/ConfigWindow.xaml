<Window x:Class="PerformanceTrayMonitor.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PerformanceTrayMonitor.Converters"
        Title="Configure Counters"
        MinWidth="600" MinHeight="420"
        Width="600" Height="420"
        ResizeMode="CanResizeWithGrip"
        Icon="/PerformanceTrayMonitor.ico"
        SizeToContent="Height">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToFontWeightConverter x:Key="BoolToFontWeight"/>

        <!-- Flash animation for buttons -->
        <Storyboard x:Key="ButtonFlashStoryboard">
            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                            To="#FFB6FFB6"
                            Duration="0:0:0.15"
                            AutoReverse="True"/>
        </Storyboard>

        <!-- Pulse animation for the details panel -->
        <Storyboard x:Key="PanelPulseStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             To="0.5"
                             Duration="0:0:0.1"
                             AutoReverse="True"/>
        </Storyboard>

        <!-- Style that flashes any button when clicked -->
        <Style TargetType="Button">
            <EventSetter Event="Click"
                         Handler="ButtonFlashHandler"/>
        </Style>

    </Window.Resources>

    <Grid Margin="12" Background="{StaticResource AppWindowGradient}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE (Grid-based layout) -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Title -->
                <RowDefinition Height="Auto"/>
                <!-- Subtitle -->
                <RowDefinition Height="*"/>
                <!-- List -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Tracked Metrics"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,2"/>

            <TextBlock Grid.Row="1"
                       Text="(Click an item to edit its details)"
                       FontStyle="Italic"
                       FontSize="11"
                       Foreground="#777"
                       Margin="0,0,0,8"/>

            <!-- Scrollable list with subtle border -->
            <Border Grid.Row="2"
                    BorderBrush="#CCC"
                    BorderThickness="1"
                    CornerRadius="2"
                    Margin="0,0,0,12">
                <ListBox ItemsSource="{Binding Counters}"
                         SelectedItem="{Binding Selected, Mode=TwoWay}"
                         IsSynchronizedWithCurrentItem="True"
                         MinHeight="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayNameProxy}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Vertical">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="Add" Width="70" Margin="0,0,4,0"
                            Command="{Binding AddCommand}"/>

                    <Button x:Name="ApplyButton"
                            Content="Apply"
                            Width="70" Margin="0,0,4,0"
                            Command="{Binding ApplyCommand}"
                            Click="ApplyButton_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Cancel" Width="70" Margin="0,0,4,0"
                            Command="{Binding CancelCommand}"/>

                    <Button Content="Remove" Width="70"
                            Command="{Binding RemoveCommand}"/>
                </StackPanel>

            </StackPanel>
        </Grid>

        <!-- RIGHT SIDE -->
        <StackPanel x:Name="DetailsPanel"
                    Grid.Column="1"
                    Margin="20,0,0,0">

            <TextBlock Text="Details"
                       FontSize="14"
                       Margin="0,0,0,8"
                       FontWeight="{Binding HasPendingEdits, Converter={StaticResource BoolToFontWeight}}"/>

            <!-- Display Name -->
            <TextBlock Text="Display Name"/>
            <TextBox Text="{Binding Editor.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <!-- Category -->
            <TextBlock Text="Category"/>
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding Editor.SelectedCategory, Mode=TwoWay}"
                      Margin="0,0,0,8"/>

            <!-- Counter -->
            <TextBlock Text="Counter"/>
            <ComboBox ItemsSource="{Binding CountersInCategory}"
                      SelectedItem="{Binding Editor.SelectedCounter, Mode=TwoWay}"
                      Margin="0,0,0,8"/>

            <!-- Instance -->
            <TextBlock Text="Instance"/>
            <ComboBox ItemsSource="{Binding Instances}"
                      SelectedItem="{Binding Editor.SelectedInstance, Mode=TwoWay}"
                      Margin="0,0,0,8"/>

            <!-- Min / Max -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Min"/>
                    <TextBox Text="{Binding Editor.Min, Mode=TwoWay}" Width="80"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Max"/>
                    <TextBox Text="{Binding Editor.Max, Mode=TwoWay}" Width="80"/>
                </StackPanel>
            </StackPanel>

            <!-- Tray Icon -->
            <GroupBox Header="Tray Icon" Margin="0,8,0,0">
                <StackPanel Margin="4">

                    <!-- Checkbox always visible -->
                    <CheckBox Content="Show in tray"
                              IsChecked="{Binding Editor.ShowInTray, Mode=TwoWay}"
                              Margin="0,0,0,6"/>

                    <!-- Collapsible Icon Set row -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding Editor.ShowInTray, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Icon Set" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding AvailableIconSets}"
                                  SelectedItem="{Binding Editor.IconSet, Mode=TwoWay}"
                                  Width="150"/>
                    </StackPanel>

                </StackPanel>
            </GroupBox>

            <!-- Bottom Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">

                <Button Content="Reset to Defaults"
                        Width="120" Margin="0,0,8,0"
                        Command="{Binding ResetCommand}"/>

                <Button Content="Save &amp; Close"
                        Width="100"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>