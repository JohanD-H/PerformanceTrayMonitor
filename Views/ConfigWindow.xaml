<Window x:Class="PerformanceTrayMonitor.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Counters"
        SizeToContent="Height"
        MinWidth="650" MinHeight="430"
        Width="650" Height="430"
        ResizeMode="CanResizeWithGrip"
        Icon="D:\Visual Studio\PerformanceTrayMonitor\Resources\Icons\App\app.ico">

    <Window.Resources>

        <!-- Flash animation for buttons -->
        <Storyboard x:Key="ButtonFlashStoryboard">
            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                            To="#FFB6FFB6"
                            Duration="0:0:0.15"
                            AutoReverse="True"/>
        </Storyboard>

        <!-- Pulse animation for the details panel -->
        <Storyboard x:Key="PanelPulseStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             To="0.5"
                             Duration="0:0:0.1"
                             AutoReverse="True"/>
        </Storyboard>

        <!-- Style that flashes any button when clicked -->
        <Style TargetType="Button">
            <EventSetter Event="Click"
                         Handler="ButtonFlashHandler"/>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <StackPanel Grid.Column="0">
            <TextBlock Text="Counters" FontWeight="Bold" Margin="0,0,0,4"/>

            <ListBox ItemsSource="{Binding Counters}"
                     SelectedItem="{Binding Selected, Mode=TwoWay}"
                     IsSynchronizedWithCurrentItem="True"
                     Margin="0,0,0,8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayNameProxy}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Orientation="Vertical" Margin="0,8,0,0">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">

                    <Button Content="Add"
                            Width="70" Margin="0,0,4,0"
                            Command="{Binding AddCommand}"/>

                    <Button x:Name="ApplyButton"
                            Content="Apply"
                            Width="70" Margin="0,0,4,0"
                            Command="{Binding ApplyCommand}"
                            Click="ApplyButton_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Cancel"
                            Width="70" Margin="0,0,4,0"
                            Command="{Binding CancelCommand}"/>

                    <Button Content="Remove"
                            Width="70"
                            Command="{Binding RemoveCommand}"/>
                </StackPanel>

            </StackPanel>
        </StackPanel>

        <!-- RIGHT SIDE -->
        <StackPanel x:Name="DetailsPanel"
                    Grid.Column="1"
                    Margin="12,0,0,0">

            <TextBlock Text="Details" FontWeight="Bold" Margin="0,0,0,4"/>

            <TextBlock Text="Display Name"/>
            <TextBox Text="{Binding Editor.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,4"/>

            <TextBlock Text="Category"/>
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding Editor.Category, Mode=TwoWay}"
                      Margin="0,0,0,4"/>

            <TextBlock Text="Counter"/>
            <ComboBox ItemsSource="{Binding CountersInCategory}"
                      SelectedItem="{Binding Editor.Counter, Mode=TwoWay}"
                      Margin="0,0,0,4"/>

            <TextBlock Text="Instance"/>
            <ComboBox ItemsSource="{Binding Instances}"
                      SelectedItem="{Binding Editor.Instance, Mode=TwoWay}"
                      Margin="0,0,0,4"/>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Min"/>
                    <TextBox Text="{Binding Editor.Min, Mode=TwoWay}"
                             Width="80"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Max"/>
                    <TextBox Text="{Binding Editor.Max, Mode=TwoWay}"
                             Width="80"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Mode" Margin="0,4,0,0"/>
            <ComboBox ItemsSource="{Binding Modes}"
                      SelectedItem="{Binding Editor.Mode, Mode=TwoWay}"/>

            <GroupBox Header="Tray Icon" Margin="0,8,0,0">
                <StackPanel>
                    <CheckBox Content="Show in tray"
                              IsChecked="{Binding Editor.ShowInTray, Mode=TwoWay}"/>

                    <ComboBox ItemsSource="{Binding IconSets}"
                              SelectedItem="{Binding Editor.IconSet, Mode=TwoWay}"
                              IsEnabled="{Binding Editor.ShowInTray}"/>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">

                <Button Content="Reset to Defaults"
                        Width="120" Margin="0,0,8,0"
                        Command="{Binding ResetCommand}"/>

                <Button Content="Save &amp; Close"
                        Width="100"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
