<Window x:Class="PerformanceTrayMonitor.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PerformanceTrayMonitor.Views"
        Title="Performance Tray Monitor"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="420"
        Height="260"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Icon="/Views/app.ico">

    <Border CornerRadius="10"
            BorderBrush="#33000000"
            BorderThickness="1"
            Background="#F8FFFFFF"
            SnapsToDevicePixels="True">

        <Grid Background="{StaticResource AppWindowGradient}">

            <!-- Ambient sparkline -->
            <local:SparkLine x:Name="BackgroundSparkline"
                             Stroke="{x:Static Brushes.DeepSkyBlue}"
                             StrokeThickness="2"
                             Opacity="0.35"
                             IsHitTestVisible="False"
                             Margin="0"/>

            <!-- Content -->
            <StackPanel Margin="20" VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal"
                            Margin="0 0 0 8"
                            VerticalAlignment="Center">

                    <Image Source="/Views/app.png"
                           Width="20"
                           Height="20"
                           Margin="0 0 8 0"
                           SnapsToDevicePixels="True"
                           UseLayoutRounding="True"/>

                    <TextBlock Text="Performance Tray Monitor"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#222"/>
                </StackPanel>

                <TextBlock x:Name="VersionTextBlock"
                           FontSize="14"
                           Foreground="#444"
                           Margin="0 0 0 12"
                           Text="Version ..." />

                <TextBlock Text="Created by Johan. Animation concepts inspired by Copilot."
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="#444"
                           Margin="0 0 0 12"/>

                <TextBlock Text="A lightweight, animated performance monitor for the Windows system tray."
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="#444"
                           Margin="0 0 0 20"/>

                <Button Content="OK"
                        Width="80"
                        HorizontalAlignment="Center"
                        Padding="6 2"
                        Margin="0 14 0 0"
                        Click="OkButton_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
