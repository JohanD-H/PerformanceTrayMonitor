<Window x:Class="PerformanceTrayMonitor.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Performance Tray Monitor"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <StackPanel Margin="20">
        <TextBlock Text="Performance Tray Monitor" 
                   FontSize="20" FontWeight="Bold" Margin="0 0 0 10"/>

        <TextBlock Text="Version 1.0.0" Margin="0 0 0 10"/>

        <TextBlock Text="Created by Johan. Tray icon animation concept inspired by Copilot." Margin="0 0 0 10"/>

        <TextBlock Text="A lightweight, animated performance monitor for the Windows system tray." 
                   TextWrapping="Wrap" Margin="0 0 0 20"/>

        <Button Content="OK" Width="80" HorizontalAlignment="Center" Click="Close_Click"/>
    </StackPanel>
</Window>
